<Window x:Class="SignatureBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Signature Bridge"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True"
        WindowState="Normal"
        Background="#000000"
        RenderOptions.BitmapScalingMode="HighQuality">
    <Grid>
        <Grid x:Name="IdleView">
            <Image x:Name="LogoImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
            <Button x:Name="ConfigButton"
                    Content="⚙"
                    Width="40"
                    Height="40"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="10"
                    FontSize="20"
                    Background="#3b82f6"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="OnConfigButtonClick"
                    ToolTip="Open Configuration">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="20"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
        <Grid x:Name="SigningView" Visibility="Collapsed">
            <wv2:WebView2 x:Name="SigningBrowser" DefaultBackgroundColor="#000000" />
        </Grid>
    </Grid>
</Window>
